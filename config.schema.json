{
  "$defs": {
    "CoalesceRule": {
      "properties": {
        "match": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Match"
        },
        "strategy": {
          "$ref": "#/$defs/CoalesceStrategy"
        },
        "window": {
          "title": "Window",
          "type": "number"
        },
        "aggregation": {
          "default": "latest",
          "title": "Aggregation",
          "type": "string"
        }
      },
      "required": [
        "match",
        "strategy",
        "window"
      ],
      "title": "CoalesceRule",
      "type": "object"
    },
    "CoalesceStrategy": {
      "enum": [
        "debounce",
        "batch"
      ],
      "title": "CoalesceStrategy",
      "type": "string"
    },
    "DatabaseConfig": {
      "properties": {
        "days": {
          "default": 30,
          "title": "Days",
          "type": "integer"
        },
        "db_path": {
          "default": "./data/data2.db",
          "title": "Db Path",
          "type": "string"
        },
        "echo": {
          "default": false,
          "title": "Echo",
          "type": "boolean"
        }
      },
      "title": "DatabaseConfig",
      "type": "object"
    },
    "FakturyOnlineSourceConfig": {
      "additionalProperties": false,
      "properties": {
        "type": {
