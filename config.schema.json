          "items": {
            "$ref": "#/$defs/CoalesceRule"
          },
          "title": "Coalesce",
          "type": "array"
        },
        "api_key": {
          "title": "Api Key",
          "type": "string"
        },
        "email": {
          "title": "Email",
          "type": "string"
        },
        "poll_interval": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "max_days_back": {
          "default": 30,
          "title": "Max Days Back",
          "type": "integer"
        }
      },
      "title": "FakturyOnlineSourceConfig",
      "type": "object"
    },
