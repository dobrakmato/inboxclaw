        "event_ttl": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Event Ttl",
          "type": "object"
        },
        "type": {
          "const": "http_pull",
          "default": "http_pull",
          "title": "Type",
          "type": "string"
        },
        "match": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "default": "*",
          "title": "Match"
        },
        "path": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Path",
          "type": "object"
