          },
          {
            "$ref": "#/$defs/HomeAssistantSourceConfig"
          },
          {
            "$ref": "#/$defs/NordigenSourceConfig"
          }
        ]
      },
      "title": "Sources",
      "type": "object",
      "properties": {
        "gmail": {
          "$ref": "#/$defs/GmailSourceConfig"
        },
        "google_drive": {
          "$ref": "#/$defs/GoogleDriveSourceConfig"
        },
        "google_calendar": {
          "$ref": "#/$defs/GoogleCalendarSourceConfig"
        },
        "faktury_online": {
          "$ref": "#/$defs/FakturyOnlineSourceConfig"
        },
        "fio": {
          "$ref": "#/$defs/FioSourceConfig"
        },
        "mock": {
          "$ref": "#/$defs/MockSourceConfig"
        },
        "home_assistant": {
          "$ref": "#/$defs/HomeAssistantSourceConfig"
        },
        "nordigen": {
          "$ref": "#/$defs/NordigenSourceConfig"
        }
      }
    },
    "sink": {
      "additionalProperties": {
