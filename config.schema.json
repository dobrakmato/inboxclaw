  "properties": {
    "server": {
      "$ref": "#/$defs/ServerConfig",
      "default": {
        "host": "0.0.0.0",
        "port": 8000
      }
    },
    "database": {
      "$ref": "#/$defs/DatabaseConfig"
    },
    "sources": {
