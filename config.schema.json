          {
            "$ref": "#/$defs/GmailSourceConfig"
          },
          {
            "$ref": "#/$defs/GoogleDriveSourceConfig"
          },
          {
            "$ref": "#/$defs/GoogleCalendarSourceConfig"
          },
          {
            "$ref": "#/$defs/FakturyOnlineSourceConfig"
          },
          {
            "$ref": "#/$defs/FioSourceConfig"
          },
          {
