        "single_events": {
          "default": true,
          "title": "Single Events",
          "type": "boolean"
        },
        "collapse_recurring_events": {
          "default": true,
          "title": "Collapse Recurring Events",
          "type": "boolean"
        }
      },
      "required": [
        "token_file"
      ],
      "title": "GoogleCalendarSourceConfig",
      "type": "object"
    },
    "GoogleDriveSourceConfig": {
      "additionalProperties": false,
