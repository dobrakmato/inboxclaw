        "update_quiet_window": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "update_max_session": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
